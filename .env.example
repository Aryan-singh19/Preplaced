# Placemate AI Environment Variables
PORT=3000
NODE_ENV=development

# Database Configuration
# You can use a local MongoDB instance or a free MongoDB Atlas cloud instance
MONGO_URI=mongodb://127.0.0.1:27017/placemate_db

# JWT Authentication Secret
# This is NOT an external API token. Put any random string of your choice here (e.g., a long random word or phrase) to sign user login sessions.
JWT_SECRET=any_random_string_of_your_choice_here

# AI Model Credentials (Hugging Face / Gemini)
# 1. Google Gemini Developer API Key (Recommended for high speed)
GEMINI_API_KEY=

# 2. Hugging Face Access Token (For open-source model fallback)
HF_TOKEN=

